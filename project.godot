; 小魔典 Little Grimoire — 拟物数字桌板（Godot 版）
; 引擎：Godot 4.6.3，语言 GDScript。
; 渲染：gl_compatibility（OpenGL/WebGL2）—— Web + iOS 都稳。

config_version=5

[application]

config/name="小魔典"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.png"
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=true
boot_splash/image="res://splash.png"
boot_splash/fullsize=false
boot_splash/use_filter=true

[display]

window/size/viewport_width=1170
window/size/viewport_height=2532
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
